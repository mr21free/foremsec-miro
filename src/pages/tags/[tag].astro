---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import PageLayout from '../../layouts/PageLayout.astro';
import { getReadingTime } from '../../utils/reading-time';
import { slugify, withBase } from '../../utils/slugify';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const projects = await getCollection('projects');
	const tags = new Map<string, string>();

	[...posts, ...projects].forEach((entry) => {
		(entry.data.tags ?? []).forEach((tag) => {
			tags.set(slugify(tag), tag);
		});
	});

	return Array.from(tags.entries()).map(([slug, label]) => ({
		params: { tag: slug },
		props: { tagLabel: label },
	}));
}

interface Props {
	tagLabel: string;
}

const { tagLabel } = Astro.props as Props;
const tagParam = Astro.params.tag ?? '';
const posts = (await getCollection('blog'))
	.filter((post) => (post.data.tags ?? []).some((tag) => slugify(tag) === tagParam))
	.map((post) => ({
		title: post.data.title,
		href: withBase(`/blog/${post.id}/`),
		description: post.data.description,
		date: post.data.pubDate,
		readingTime: getReadingTime(post.body, (post.body.match(/!\[[^\]]*\]\([^)]+\)/g) || []).length + (post.data.heroImage ? 1 : 0)).text,
		image: post.data.heroImage,
		imageAlt: post.data.title,
		type: 'Blog',
		tags: post.data.tags ?? [],
	}));

const projects = (await getCollection('projects'))
	.filter((project) => (project.data.tags ?? []).some((tag) => slugify(tag) === tagParam))
	.map((project) => ({
		title: project.data.title,
		href: withBase(`/projects/${project.id}/`),
		description: project.data.description,
		date: project.data.pubDate,
		readingTime: getReadingTime(project.body, (project.body.match(/!\[[^\]]*\]\([^)]+\)/g) || []).length + (project.data.heroImage ? 1 : 0)).text,
		image: project.data.heroImage,
		imageAlt: project.data.title,
		type: 'Project',
		tags: project.data.tags ?? [],
	}));

const items = [...posts, ...projects].sort((a, b) => b.date.valueOf() - a.date.valueOf());
const itemCount = items.length;
---

<PageLayout title={`Tag: ${tagLabel}`} description={`${itemCount} article${itemCount === 1 ? '' : 's'} and project${itemCount === 1 ? '' : 's'} tagged with ${tagLabel}, spanning Bitcoin, security, product work, and freedom.`}>
	<section class="content-shell py-12 space-y-10">
		<header class="mx-auto w-full max-w-5xl space-y-2">
			<p class="text-sm uppercase tracking-[0.3em] text-muted">Tag</p>
			<h1 class="text-3xl font-semibold text-ink">{tagLabel}</h1>
			<p class="text-muted">{itemCount} article{itemCount === 1 ? '' : 's'} and project{itemCount === 1 ? '' : 's'} tagged with {tagLabel}.</p>
		</header>

		{items.length === 0 ? (
			<p class="text-muted">No content found for this tag.</p>
		) : (
			<div class="mx-auto max-w-5xl border-y border-[color:var(--color-border)] divide-y divide-[color:var(--color-border)] pt-6 pb-6">
				{items.map((item) => (
					<article
						class="group relative cursor-pointer py-8 first:pt-0 last:pb-0"
						data-href={item.href}
						role="link"
						tabindex="0"
						onclick="if(!event.target.closest('a,button,input,textarea,select,details,[role=button]')){location.href=this.dataset.href}"
						onkeydown="if((event.key==='Enter'||event.key===' ')&&!event.target.closest('a,button,input,textarea,select,details,[role=button]')){location.href=this.dataset.href}"
					>
						<a class="sr-only" href={item.href}>Open {item.title}</a>
						<div class="grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,1fr)_17rem] lg:gap-8 lg:items-start">
							<div class="order-2 flex min-w-0 flex-col justify-start lg:order-1">
								<p class="text-sm uppercase tracking-[0.3em] text-muted">{item.type}</p>
								<h2 class="mt-2 text-2xl font-semibold leading-tight text-ink transition duration-200 group-hover:text-[color:var(--color-primary)]">
									{item.title}
								</h2>
								<p class="mt-2 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-muted">
									<FormattedDate date={item.date} />
									{item.readingTime && <span aria-hidden="true">·</span>}
									{item.readingTime && <span>{item.readingTime}</span>}
								</p>
								<p class="mt-4 text-base leading-7 text-muted">
									{item.description}
								</p>
								{item.tags.length > 0 && (
									<div class="mt-5 flex flex-wrap gap-2">
										{item.tags.map((tag) => (
											<a
												class="inline-flex items-center rounded-full border border-[color:var(--color-border)] bg-[color-mix(in_oklab,var(--color-surface)_95%,transparent)] px-3 py-1 text-sm text-muted hover:text-ink"
												href={withBase(`/tags/${slugify(tag)}/`)}
											>
												{tag}
											</a>
										))}
									</div>
								)}
							</div>
							<div class="order-1 space-y-6 lg:order-2">
								{item.image && (
									<figure class="m-0 overflow-hidden rounded-[1.5rem] bg-[color-mix(in_oklab,var(--color-ink)_4%,var(--color-surface))]">
										<Image
											src={item.image}
											alt={item.imageAlt}
											width={720}
											height={420}
											loading="lazy"
											format="webp"
											quality={82}
											class="block h-full w-full object-cover object-top transition duration-300 group-hover:scale-[1.03]"
										/>
									</figure>
								)}
							</div>
						</div>
					</article>
				))}
			</div>
		)}
	</section>
</PageLayout>
