---
import { getCollection } from 'astro:content';
import Card from '../../components/Card.astro';
import PageLayout from '../../layouts/PageLayout.astro';
import { slugify, withBase } from '../../utils/slugify';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const projects = await getCollection('projects');
	const tags = new Map<string, string>();

	[...posts, ...projects].forEach((entry) => {
		(entry.data.tags ?? []).forEach((tag) => {
			tags.set(slugify(tag), tag);
		});
	});

	return Array.from(tags.entries()).map(([slug, label]) => ({
		params: { tag: slug },
		props: { tagLabel: label },
	}));
}

interface Props {
	tagLabel: string;
}

const { tagLabel } = Astro.props as Props;
const tagParam = Astro.params.tag ?? '';
const posts = (await getCollection('blog'))
	.filter((post) => (post.data.tags ?? []).some((tag) => slugify(tag) === tagParam))
	.map((post) => ({
		title: post.data.title,
		href: withBase(`/blog/${post.id}/`),
		description: post.data.description,
		date: post.data.pubDate,
		image: post.data.heroImage,
		imageAlt: post.data.title,
		type: 'Blog',
		tags: post.data.tags ?? [],
	}));

const projects = (await getCollection('projects'))
	.filter((project) => (project.data.tags ?? []).some((tag) => slugify(tag) === tagParam))
	.map((project) => ({
		title: project.data.title,
		href: withBase(`/projects/${project.id}/`),
		description: project.data.description,
		date: project.data.pubDate,
		image: project.data.heroImage,
		imageAlt: project.data.title,
		type: 'Project',
		tags: project.data.tags ?? [],
	}));

const items = [...posts, ...projects].sort((a, b) => b.date.valueOf() - a.date.valueOf());
---

<PageLayout title={`Tag: ${tagLabel}`} description={`Articles and projects tagged with ${tagLabel}.`}>
	<section class="content-shell py-12 space-y-6">
		<header class="space-y-2">
			<p class="text-sm uppercase tracking-[0.3em] text-muted">Tag</p>
			<h1 class="text-3xl font-semibold text-ink">{tagLabel}</h1>
			<p class="text-muted">Articles and projects tagged with {tagLabel}.</p>
		</header>

		{items.length === 0 ? (
			<p class="text-muted">No content found for this tag.</p>
		) : (
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
				{items.map((item) => (
					<Card
						title={item.title}
						href={item.href}
						description={item.description}
						date={item.date}
						image={item.image}
						imageAlt={item.imageAlt}
						eyebrow={item.type}
					>
						{item.tags.length > 0 && (
							<div class="flex flex-wrap gap-2 pt-1 text-sm text-muted">
								{item.tags.map((tag) => (
									<a
										class="inline-flex items-center gap-2 rounded-full border border-[color:var(--color-border)] bg-[color-mix(in_oklab,var(--color-surface)_95%,transparent)] px-3 py-1 hover:text-ink"
										href={withBase(`/tags/${slugify(tag)}/`)}
									>
										{tag}
									</a>
								))}
							</div>
						)}
					</Card>
				))}
			</div>
		)}
	</section>
</PageLayout>
