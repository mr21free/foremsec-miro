---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import ProjectPost from '../../layouts/ProjectPost.astro';
import { getReadingTime } from '../../utils/reading-time';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.id },
		props: project,
	}));
}

type Props = CollectionEntry<'projects'>;

const project = Astro.props as Props;
const { Content } = await render(project);
const imageCount = (project.body.match(/!\[[^\]]*\]\([^)]+\)/g) || []).length + (project.data.heroImage ? 1 : 0);
const readingTime = getReadingTime(project.body, imageCount);
---
<ProjectPost {...project.data} readingTime={readingTime.text}>
	<Content />
</ProjectPost>
