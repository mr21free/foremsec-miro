---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import PageLayout from '../../layouts/PageLayout.astro';
import { getReadingTime } from '../../utils/reading-time';

import { slugify, withBase } from '../../utils/slugify';

const posts = (await getCollection('blog'))
  .filter((post) => post.data.draft !== true)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function getListReadingTime(entry: { body?: string; data?: { heroImage?: unknown } }) {
  const body = entry.body ?? '';
  if (!body) return null;
  const imageCount = (body.match(/!\[[^\]]*\]\([^)]+\)/g) || []).length + (entry.data?.heroImage ? 1 : 0);
  return getReadingTime(body, imageCount).text;
}
---	

<PageLayout title="Blog" description="Essays, field notes, and practical guides on Bitcoin, security, products, and freedom.">
	<section class="content-shell py-12 space-y-10">
		<header class="mx-auto w-full max-w-5xl space-y-2">
			<p class="text-sm uppercase tracking-[0.3em] text-muted">Blog</p>
			<h1 class="text-3xl font-semibold text-ink">Notes, guides, and longer thoughts</h1>
			<p class="max-w-3xl text-muted">Writing about Bitcoin, security, product work, freedom, and the tradeoffs that sit underneath all of it.</p>
		</header>

		{posts.length === 0 ? (
			<p class="text-muted">No blog posts published yet.</p>
		) : (
			<div class="mx-auto max-w-5xl border-y border-[color:var(--color-border)] divide-y divide-[color:var(--color-border)] pt-6 pb-6">
				{posts.map((post) => {
					const readingTime = getListReadingTime(post);
					return <article
						class="group relative cursor-pointer py-8 first:pt-0 last:pb-0"
						data-href={withBase(`/blog/${post.id}/`)}
						role="link"
						tabindex="0"
						onclick="if(!event.target.closest('a,button,input,textarea,select,details,[role=button]')){location.href=this.dataset.href}"
						onkeydown="if((event.key==='Enter'||event.key===' ')&&!event.target.closest('a,button,input,textarea,select,details,[role=button]')){location.href=this.dataset.href}"
					>
						<a class="sr-only" href={withBase(`/blog/${post.id}/`)}>Open {post.data.title}</a>
						<div class="grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,1fr)_17rem] lg:gap-8 lg:items-start">
							<div class="order-2 flex min-w-0 flex-col justify-start lg:order-1">
								<h2 class="text-2xl font-semibold leading-tight text-ink transition duration-200 group-hover:text-[color:var(--color-primary)]">
									{post.data.title}
								</h2>
								<p class="mt-2 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-muted">
									<FormattedDate date={post.data.pubDate} />
									{readingTime && <span aria-hidden="true">·</span>}
									{readingTime && <span>{readingTime}</span>}
								</p>
								<p class="mt-4 text-base leading-7 text-muted">
									{post.data.description}
								</p>
								{post.data.tags.length > 0 && (
									<div class="mt-5 flex flex-wrap gap-2">
										{post.data.tags.map((tag) => (
											<a
												class="inline-flex items-center rounded-full border border-[color:var(--color-border)] bg-[color-mix(in_oklab,var(--color-surface)_95%,transparent)] px-3 py-1 text-sm text-muted hover:text-ink"
												href={withBase(`/tags/${slugify(tag)}/`)}
											>
												{tag}
											</a>
										))}
									</div>
								)}
							</div>
							<div class="order-1 space-y-6 lg:order-2">
								{post.data.heroImage && (
									<figure class="m-0 overflow-hidden rounded-[1.5rem] bg-[color-mix(in_oklab,var(--color-ink)_4%,var(--color-surface))]">
										<Image
											src={post.data.heroImage}
											alt={post.data.title}
											width={720}
											height={420}
											loading="lazy"
											format="webp"
											quality={82}
											class="block h-full w-full object-cover object-top transition duration-300 group-hover:scale-[1.03]"
										/>
									</figure>
								)}
							</div>
						</div>
					</article>;
				})}
			</div>
		)}
	</section>
</PageLayout>
