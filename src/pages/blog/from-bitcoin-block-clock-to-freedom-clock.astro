---
const targetPath = '/projects/from-bitcoin-block-clock-to-freedom-clock/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Redirecting...</title>
    <meta http-equiv="refresh" content={`0;url=${targetPath}`} />
    <link rel="canonical" href={targetPath} />
    <meta name="robots" content="noindex" />
    <script is:inline>
      window.location.replace('/projects/from-bitcoin-block-clock-to-freedom-clock/');
    </script>
  </head>
  <body>
    <p>
      Redirecting to
      <a href={targetPath}>the project page</a>.
    </p>
  </body>
</html>
