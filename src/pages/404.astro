---
import PageLayout from '../layouts/PageLayout.astro';
import { withBase } from '../utils/slugify';
---

<PageLayout title="Page not found" description="Even the honey badger couldn’t find this page.">
  <section class="content-shell py-10 md:py-14">
    <div class="mx-auto flex max-w-4xl flex-col items-center gap-6 text-center">
      <p class="m-0 text-3xl font-semibold leading-tight text-ink sm:text-4xl">Oops...</p>

      <img
        src={withBase('/images/honey-badger-404.png')}
        alt="Confused honey badger under the moon"
        width="1536"
        height="1024"
        class="w-full max-w-4xl rounded-[2rem] border border-[color-mix(in_oklab,var(--color-ink)_12%,transparent)]"
        loading="eager"
        decoding="async"
      />

      <h1 class="m-0 text-3xl font-semibold leading-tight text-ink sm:text-4xl">
        Even the honey badger couldn&apos;t find this page.
      </h1>

      <a class="button primary" href={withBase('/')}>Take Me Home</a>
    </div>
  </section>
</PageLayout>
