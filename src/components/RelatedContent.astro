---
import type { ImageMetadata } from 'astro';
import Card from './Card.astro';

interface RelatedItem {
	title: string;
	description?: string;
	href: string;
	pubDate?: Date;
	heroImage?: ImageMetadata;
}

interface Props {
	heading: string;
	items?: RelatedItem[];
	archiveHref: string;
	archiveLabel: string;
	emptyLabel?: string;
}

const {
	heading,
	items = [],
	archiveHref,
	archiveLabel,
	emptyLabel = 'More coming soon.',
} = Astro.props as Props;
---

<section class="related-content">
	<div class="related-content__header">
		<p class="eyebrow">Keep Reading</p>
		<h2>{heading}</h2>
	</div>

	{items.length > 0 ? (
		<div class="related-content__grid">
			{items.map((item) => (
				<div class="card post-card">
					<Card
						title={item.title}
						href={item.href}
						description={item.description}
						date={item.pubDate}
						image={item.heroImage}
						imageAlt={item.title}
					/>
				</div>
			))}
		</div>
	) : (
		<p class="text-muted">{emptyLabel}</p>
	)}

	<div class="related-content__footer">
		<a class="button secondary" href={archiveHref}>{archiveLabel}</a>
	</div>
</section>
